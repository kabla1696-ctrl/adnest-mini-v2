{
"manifest_version": 3,
"name": "AdNest Mini",
"version": "0.0.6",
"description": "Sponsored widget with Adsterra smartlink support.",
"permissions": ["storage"],
"host_permissions": [
"<all_urls>",
"https://api1.adsterra.com/*"
],
"background": {
"service_worker": "background.js"
},
"action": {
"default_popup": "popup.html"
},
"options_page": "options.html",
"content_scripts": [
{
"matches": ["<all_urls>"],
"js": ["content.js"],
"run_at": "document_idle"
}
]
}
